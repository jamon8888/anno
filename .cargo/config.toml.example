# Local developer overrides for the `anno` workspace.
#
# Usage:
# - Copy this file to `.cargo/config.toml`
# - Adjust paths if you keep repos elsewhere
#
# Notes:
# - This keeps the repo buildable standalone (default deps are crates.io + git),
#   while still allowing fast iteration with local sibling checkouts.

[patch.crates-io]
textprep = { path = "../textprep" }

# Default in-repo is a pinned git rev for reproducibility/CI.
# For faster local dev (edit+test without git fetch), you can override the git dependency
# to a sibling checkout:
[patch."https://github.com/arclabs561/muxer.git"]
muxer = { path = "../muxer" }# `gramdex` is a git dependency by default (so CI works without sibling checkouts).
# If you have a local checkout, you can override it here.
[patch."https://github.com/arclabs561/gramdex"]
gramdex = { path = "../gramdex" }