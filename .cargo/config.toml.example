[patch.crates-io]
# Local super-workspace dev override. Do NOT commit; .cargo/config.toml is gitignored.
#
# If you have sibling checkouts (e.g. `dev/textprep/`) next to `dev/anno/`, add the stanzas below
# to your `.cargo/config.toml` (create it if missing).
#
# If you already have a `.cargo/config.toml`, merge this block into it (do not overwrite).
# A diff/merge tool (e.g. `meld`) makes this painless.
textprep = { path = "../textprep" }
logp = { path = "../logp" }
pare = { path = "../pare" }
muxer = { path = "../muxer" }

