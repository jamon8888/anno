{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}/scripts/agent-harness/prompt-secret-scan.ps1\"",
            "shell": "powershell",
            "timeout": 20,
            "statusMessage": "secret scan ..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}/scripts/agent-harness/block-dangerous-tool.ps1\"",
            "shell": "powershell",
            "timeout": 20,
            "statusMessage": "safety gate ..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}/scripts/agent-harness/post-edit-rust-check.ps1\"",
            "shell": "powershell",
            "timeout": 90,
            "statusMessage": "targeted Rust check ...",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}/scripts/agent-harness/stop-verify.ps1\"",
            "shell": "powershell",
            "timeout": 30,
            "statusMessage": "completion gate ..."
          }
        ]
      }
    ]
  }
}
